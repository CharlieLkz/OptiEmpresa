# ===== Mailu - Nodo A (empresa.ComSoc) =====
# IMPORTANTE: SECRET_KEY debe tener EXACTAMENTE 16 caracteres.
SECRET_KEY=ComSocKey1234567

# Subred interna de Mailu (coincide con docker-compose.mail.yml)
SUBNET=192.168.203.0/24

# Dominio principal (Mailu lo guarda en minúsculas)
DOMAIN=empresa.comsoc
HOSTNAMES=correo.empresa.comsoc
POSTMASTER=admin
SITENAME=Empresa ComSoc

# Red AISLADA: sin TLS automático (no hay internet ni Let's Encrypt)
TLS_FLAVOR=notls

# Activar panel de administración y webmail
ADMIN=true
WEBMAIL=roundcube
WEBDAV=false
ANTIVIRUS=none          # ahorra RAM (clamav consume mucho)
FETCHMAIL_ENABLED=False

# Rutas web detrás del proxy
WEB_ADMIN=/admin
WEB_WEBMAIL=/

# Reduce ruido en laboratorio
DISABLE_STATISTICS=True
RECIPIENT_DELIMITER=+
MESSAGE_SIZE_LIMIT=50000000
COMPRESSION=
AUTH_RATELIMIT_IP=60/hour
AUTH_RATELIMIT_USER=100/day

# Credenciales Redis internas
REDIS_ADDRESS=redis
